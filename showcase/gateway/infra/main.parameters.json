{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": { "value": "${AZURE_ENV_NAME}" },
    "location": { "value": "${AZURE_LOCATION}" },
    "foundryAccountResourceId": { "value": "${FOUNDRY_ACCOUNT_RESOURCE_ID}" },
    "foundryProjectEndpoint": { "value": "${FOUNDRY_PROJECT_ENDPOINT}" },
    "modelDeploymentName": { "value": "${AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1}" },
    "allowedOrigins": { "value": "${ALLOWED_ORIGINS=https://lordlinus.github.io}" }
  }
}
