# Showcase gateway environment.
#
# REAL keyless Foundry (default). DefaultAzureCredential picks up `az login`
# locally or the Container App's managed identity in Azure. Both vars are required:
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry>.services.ai.azure.com/api/projects/<project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1

# Offline path (no Azure, no cost) — only for plumbing tests/CI. Leave UNSET for real:
# LLM_MODE=mock

# Browser origins allowed to call the gateway (comma-separated). Include your
# GitHub Pages URL in production.
ALLOWED_ORIGINS=https://lordlinus.github.io,http://localhost:5173,http://localhost:8080

# Optional shared API key forwarded to backends (set AG_UI_API_KEY in each backend
# to require it). Leave unset for an open public demo.
# AG_UI_API_KEY=
