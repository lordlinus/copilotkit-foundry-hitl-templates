# Copilot PR Assistant (Copilot SDK) — environment.
#
# Azure BYOM (Bring Your Own Model). The GitHub Copilot SDK encrypts prompts, so
# ONLY o-series / gpt-5 family deployments work (gpt-4.x is unsupported).
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
MODEL_NAME=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Auth: local dev uses DefaultAzureCredential (az login); production uses
# ManagedIdentityCredential. NODE_ENV=development selects DefaultAzureCredential.
NODE_ENV=development
# AZURE_CLIENT_ID=        # user-assigned managed identity client id (in Azure)

# Port the AG-UI server listens on (the showcase gateway proxies here).
PORT=8104
