# Bridge (backend/bridge_app.py) config — copy to backend/.env (gitignored) for
# local dev. The bridge is a thin AG-UI↔Responses proxy; the agent itself runs
# either locally via `azd ai agent run` or as a deployed Foundry hosted agent.

# ── Local dev (`make local` / `make smoke`) ───────────────────────────────────
# These set HOSTED_AGENT_DIRECT_URL automatically (the bridge points at the agent
# that `azd ai agent run` serves on :8088). You don't need to set anything here.

# ── Drive a DEPLOYED hosted agent from the bridge ─────────────────────────────
# Requires `az login` to the tenant that owns the Foundry project (keyless).
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-account>.services.ai.azure.com/api/projects/<your-project>
HOSTED_AGENT_NAME=<the deployed agent name>

# ── Optional: protect the AG-UI endpoint with a shared key ────────────────────
# AG_UI_API_KEY=
