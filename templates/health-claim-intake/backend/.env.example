# Copy to backend/.env (gitignored) for local dev. Pick ONE connection mode.

# ── Mode 1: offline mock (no Azure) — used by `make smoke` / CI ───────────────
# LLM_MODE=mock

# ── Mode 3 (default, recommended): keyless Azure AI Foundry ───────────────────
# Requires `az login` to the tenant that owns the Foundry project.
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-account>.services.ai.azure.com/api/projects/<your-project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1

# ── Mode 2 (optional): OpenAI-compatible gateway via key (e.g. APIM) ──────────
# LLM_API_KEY=
# LLM_BASE_URL=https://<gateway>/openai/v1
# LLM_AUTH_HEADER=Ocp-Apim-Subscription-Key

# ── Optional: protect the AG-UI endpoint with a shared key ────────────────────
# AG_UI_API_KEY=
