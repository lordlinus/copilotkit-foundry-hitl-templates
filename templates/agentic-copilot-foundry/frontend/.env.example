# Copy to frontend/.env.local (gitignored).
# URL of the AG-UI backend (FastAPI + SSE). Default works for local dev.
AG_UI_BACKEND_URL=http://localhost:8080/
# Set only if the backend enforces AG_UI_API_KEY.
# AG_UI_API_KEY=
# Comma-separated allow-list of origins permitted to call /api/copilotkit
# cross-origin (e.g. a GitHub Spark app or showcase/spark-ui). Leave unset to
# reflect any Origin (fine for Spark preview; tighten for production).
# COPILOT_ALLOWED_ORIGINS=https://my-app.github.app,http://localhost:5173
