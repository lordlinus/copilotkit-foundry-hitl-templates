# forgewright app targets. Include from Makefile (which sets APP_NAME / AGENT_NAME).
SHELL := /bin/bash
PY    ?= python3
UV    ?= uv
VENV  := backend/.venv
BPY   := $(VENV)/bin/python

.PHONY: help preflight install local verify smoke e2e up deploy up-app deploy-app clean

help:
	@echo "forgewright app ($(APP_NAME)) — targets:"
	@echo "  make preflight  check toolchain + install backend/frontend deps"
	@echo "  make local      azd ai agent run (:8088) -> AG-UI bridge/proxy (:8080) -> Next.js UI (:3000)"
	@echo "  make verify     read-only structural checks (no network)"
	@echo "  make smoke      end-to-end HITL test against the REAL agent (azd ai agent run)"
	@echo "  make e2e        Chromium UI test against the REAL agent (read/reject/approve/follow-up)"
	@echo "  make up         deploy hosted Foundry agent via azd (needs az login)"
	@echo "  make up-app     deploy the bridge + frontend as Container Apps via azd (needs 'make up' first)"
	@echo "  make deploy-app redeploy the bridge + frontend after a code change (skips provisioning)"
	@echo "  make clean      remove venvs / node_modules / .next"

install:
	@command -v $(UV) >/dev/null || { echo "uv is required — install from https://docs.astral.sh/uv/"; exit 1; }
	@test -d $(VENV) || $(UV) venv --python 3.12 $(VENV)
	@$(UV) pip install -q --python $(BPY) --prerelease=allow -r backend/requirements.txt
	@test -d frontend/node_modules || (cd frontend && npm install)

preflight: install
	@command -v node >/dev/null || { echo "node is required"; exit 1; }
	@echo "✓ preflight ok"

local: install
	@bash run-local.sh

verify:
	@bash scripts/verify.sh

smoke: install
	@bash scripts/smoke_run.sh

e2e: install
	@bash scripts/e2e_run.sh

up:
	@cd hosted && azd up

deploy:
	@cd hosted && azd deploy

up-app:
	@cd deploy && azd up

deploy-app:
	@cd deploy && azd deploy

clean:
	@rm -rf $(VENV) frontend/node_modules frontend/.next backend/__pycache__ src/__pycache__
	@echo "✓ cleaned"
